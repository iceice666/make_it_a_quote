{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types", "@cloudflare/workers-types"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
